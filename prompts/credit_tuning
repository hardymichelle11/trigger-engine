@dataclass
class FeatureSnapshot:
    ticker: str
    last: float
    mean_5: float
    mean_10: float
    mean_20: float
    std_20: float
    z20: float
    pct_change_1: float
    pct_change_5: float
    slope_5: float


@dataclass
