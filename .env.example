VITE_POLYGON_API_KEY=your_polygon_api_key_here
VITE_GCP_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./pipeline/service-account.json

# Knowledge Bot — Vertex AI (Gemini)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
BOT_PORT=3001
BOT_MODEL=gemini-2.5-flash

# ThetaData options-chain provider (Phase 4.5C)
#
# ┌─────────────────────────────────────────────────────────────────┐
# │ SECURITY:                                                        │
# │ Do not place real ThetaData secrets in VITE_ variables.          │
# │ Anything prefixed with VITE_ is bundled into the public browser  │
# │ JavaScript at build time and is therefore visible to anyone who  │
# │ loads the app.                                                   │
# │                                                                  │
# │ VITE_THETADATA_* is intentionally limited to non-secret,         │
# │ browser-safe configuration only:                                 │
# │   - VITE_THETADATA_ENABLED        master enable flag             │
# │   - VITE_THETADATA_BASE_URL       local terminal URL             │
# │   - VITE_THETADATA_TIMEOUT_MS     request timeout                │
# │                                                                  │
# │ If ThetaData ever requires a username, password, API key, or     │
# │ OAuth token, those MUST be handled by a local backend / proxy    │
# │ and read via server-side env variables WITHOUT the VITE_ prefix. │
# │ The provider factory accepts an explicit `apiKey` argument for   │
# │ that path; see src/providers/options/optionsChainProvider.js.    │
# │                                                                  │
# │ Today, Theta Terminal runs locally and handles its own login.    │
# │ The browser only talks to 127.0.0.1 — no key passes through.     │
# └─────────────────────────────────────────────────────────────────┘
#
# Leave UNSET to keep the provider in `missing_credentials` /
# `unavailable` state. The Lethal Board's Trade Construction
# Snapshot continues to work — premium label remains "estimated"
# until both:
#   1) VITE_THETADATA_ENABLED=true
#   2) Theta Terminal is running locally and reachable on the base URL
#
# The .env file is gitignored; never commit it.
#
# VITE_THETADATA_ENABLED=true
# VITE_THETADATA_BASE_URL=http://127.0.0.1:25510
# VITE_THETADATA_TIMEOUT_MS=5000
