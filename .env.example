VITE_POLYGON_API_KEY=your_polygon_api_key_here
VITE_GCP_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./pipeline/service-account.json

# Knowledge Bot — Vertex AI (Gemini)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
BOT_PORT=3001
BOT_MODEL=gemini-2.5-flash

# ThetaData options-chain provider (Phase 4.5C+2 — local Terminal v3)
#
# ┌─────────────────────────────────────────────────────────────────┐
# │ TARGET MODEL: Local Theta Terminal v3 ONLY                       │
# │                                                                  │
# │ The dashboard talks to a Java app running on the operator's      │
# │ machine at http://127.0.0.1:25503/v3. The legacy v2 model on     │
# │ port 25510 is NOT supported — v2 endpoints return HTTP 410 GONE  │
# │ on a v3 Terminal, and the adapter surfaces this as the health    │
# │ status `incompatible_version`.                                   │
# │                                                                  │
# │ The cloud-direct REST / Python library model is intentionally    │
# │ NOT used. It would require email/password (or equivalent) on     │
# │ the wire and a backend proxy to keep them off the browser bundle.│
# └─────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────┐
# │ SECURITY:                                                        │
# │ Do NOT place ThetaData email/password/API keys in VITE_ vars.    │
# │ Anything prefixed with VITE_ is bundled into the public browser  │
# │ JavaScript at build time and is therefore visible to anyone who  │
# │ loads the app.                                                   │
# │                                                                  │
# │ VITE_THETADATA_* is intentionally limited to non-secret,         │
# │ browser-safe configuration only:                                 │
# │   - VITE_THETADATA_ENABLED        master enable flag (true/false)│
# │   - VITE_THETADATA_BASE_URL       local Terminal v3 URL          │
# │   - VITE_THETADATA_TIMEOUT_MS     request timeout (ms)           │
# │                                                                  │
# │ ThetaData credentials live in `creds.txt` next to the Terminal   │
# │ jar:                                                             │
# │   line 1:  account email                                         │
# │   line 2:  password                                              │
# │ The Terminal reads creds.txt at startup and authenticates        │
# │ upstream itself. The browser never sees the credentials.         │
# │ creds.txt belongs in your Theta Terminal install directory,      │
# │ NOT in this repo, and NEVER on the wire from the dashboard.      │
# └─────────────────────────────────────────────────────────────────┘
#
# Activation is intentional: leaving these UNSET (or VITE_THETADATA_ENABLED
# unset / not "true") keeps the provider in `missing_credentials` and
# the Lethal Board's Trade Construction Snapshot stays in "estimated".
# To turn the provider on, ALL of the following must be true:
#   1) VITE_THETADATA_ENABLED=true
#   2) VITE_THETADATA_BASE_URL=/theta   (proxied by Vite — see vite.config.js)
#   3) ThetaTerminalv3.jar is running locally with valid creds.txt
#   4) Account subscription is VALUE or higher for real-time snapshot
#      quotes. FREE tier is EOD-only and cannot return live quotes.
#
# Why /theta and not http://127.0.0.1:25503 directly:
#   ThetaData Terminal v3 does not emit CORS headers, so a direct
#   cross-origin fetch from http://localhost:5173 to http://127.0.0.1:25503
#   would be blocked by the browser even though the Terminal serves
#   200 OK. The Vite dev server proxies /theta/* → http://127.0.0.1:25503/*
#   so the browser sees a same-origin request and CORS is irrelevant.
#   See vite.config.js -> server.proxy["/theta"].
#
# The .env file is gitignored; never commit it.
#
# VITE_THETADATA_ENABLED=true
# VITE_THETADATA_BASE_URL=/theta
# VITE_THETADATA_TIMEOUT_MS=5000
